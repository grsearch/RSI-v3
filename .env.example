# ==========================================
# SOL RSI Monitor v3 — Environment Config
# ==========================================

# ── Birdeye API ───────────────────────────
BIRDEYE_API_KEY=your_birdeye_api_key_here

# ── Helius RPC ────────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
HELIUS_API_KEY=your_helius_api_key_here

# ── Jupiter API ───────────────────────────
JUPITER_API_URL=https://api.jup.ag
JUPITER_API_KEY=your_jupiter_api_key_here

# ── Trading Wallet ────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Trade sizing ──────────────────────────
# 每次买入的 SOL 数量
TRADE_SIZE_SOL=0.2

# ── Slippage ──────────────────────────────
# 买入滑点（卖出自动翻倍以确保止损成交）
SLIPPAGE_BPS=300

# ── RSI 策略参数 ───────────────────────────
RSI_PERIOD=7          # RSI 计算周期（K线数）
RSI_BUY=30            # RSI 上穿此值 → 买入
RSI_SELL=75           # RSI 超过此值 → 卖出

# ── 买入过滤器 ─────────────────────────────
# 过滤器1：EMA 收敛阈值
EMA_CONVERGE_PCT=3
# 过滤器2：RSI 底背离回溯窗口
RSI_DIVERGE_BARS=20

# ── 止损 ──────────────────────────────────
STOP_LOSS_PCT=20

# ── K线 & 价格轮询 ─────────────────────────
KLINE_INTERVAL_SEC=15  # K线宽度（秒）
PRICE_POLL_SEC=5      # 价格轮询间隔（秒）

# ── 监控窗口 ──────────────────────────────
# 白名单模式：无收录门槛，监控到期后平仓退出
# 1440 = 24小时
TOKEN_MAX_AGE_MINUTES=1440

# ── 【强制退出】监控期间 FDV/LP 跌破此值则平仓移除 ──
# 注意：收录时不再检查 FDV/LP 门槛（白名单模式）
# 只有在监控期间 meta 刷新后跌破才触发退出
FDV_EXIT_USD=15000
LP_EXIT_USD=2000

# ── Server ────────────────────────────────
PORT=3001
